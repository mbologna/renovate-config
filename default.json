{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "configMigration": true,
  "prCreation": "not-pending",
  "pinDigests": true,
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "labels": [
    "dependencies"
  ],
  "commitMessageAction": "update",
  "commitMessagePrefix": "chore(deps):",
  "rebaseWhen": "behind-base-branch",
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "separateMultipleMajor": true,
  "transitiveRemediation": true,
  "dependencyDashboardTitle": "🤖 Renovate Dependency Dashboard",
  "dependencyDashboardLabels": ["renovate"],
  "vulnerabilityAlerts": {
    "description": "CVE-triggered PRs (OSV/GitHub Advisory on a version you use): add security label, fix(security): prefix, bypass age gate and schedule, automerge on green CI",
    "labels": [
      "dependencies",
      "security"
    ],
    "commitMessagePrefix": "fix(security):",
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"],
    "automerge": true
  },
  "gomod": {
    "ignorePaths": ["**/vendor/**"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeStrategy": "merge",
    "commitMessagePrefix": "chore(deps):",
    "commitMessageAction": "maintain",
    "commitMessageTopic": "lock files",
    "schedule": [
      "before 9am on monday"
    ]
  },
  "packageRules": [
    {
      "description": "Major updates: hold 30 days to let the ecosystem surface breaking changes and incompatibilities, then assign for manual review — no auto-merge",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "30 days",
      "labels": ["major"],
      "automerge": false,
      "reviewers": [
        "mbologna"
      ]
    },
    {
      "description": "Patch updates: hold 7 days to let the community catch supply-chain attacks before auto-merging on green CI",
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "7 days",
      "automerge": true
    },
    {
      "description": "Digest updates: hold 7 days (same as patch) before auto-merging on green CI",
      "matchUpdateTypes": ["digest"],
      "minimumReleaseAge": "7 days",
      "automerge": true
    },
    {
      "description": "Pin updates: hold 7 days (same as patch) before auto-merging on green CI",
      "matchUpdateTypes": ["pin"],
      "minimumReleaseAge": "7 days",
      "automerge": true
    },
    {
      "description": "Minor updates: hold 14 days to let the community catch supply-chain attacks before auto-merging on green CI",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "14 days",
      "automerge": true
    },
    {
      "description": "GitHub Actions: never auto-merge — workflow changes run with repo permissions and are a supply-chain risk",
      "matchManagers": ["github-actions"],
      "automerge": false,
      "groupName": null
    },
    {
      "description": "mbologna/.github reusable workflows: already age-gated by that repo's own Renovate run — skip stability window, bypass schedule, automerge on green CI, and clear reviewer assigned by the major rule",
      "matchManagers": ["github-actions"],
      "matchDepNames": ["mbologna/.github"],
      "minimumReleaseAge": "0 days",
      "schedule": ["at any time"],
      "automerge": true,
      "reviewers": []
    },
    {
      "description": "Security-categorised packages (e.g. cryptography, openssl — any update, not just CVE-triggered): fix(security): prefix, bypass age gate and schedule, jump queue with prPriority 10, automerge on green CI. Settings intentionally mirror vulnerabilityAlerts so both paths get the same urgency; prPriority is the only setting not covered there.",
      "matchCategories": ["security"],
      "commitMessagePrefix": "fix(security):",
      "minimumReleaseAge": "0 days",
      "prPriority": 10,
      "automerge": true,
      "schedule": ["at any time"]
    },
    {
      "description": "Regex-managed versions: one PR per package; include from/to versions and update type",
      "matchManagers": ["regex", "custom.regex"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "groupName": null,
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "Regex-managed digest updates: show short SHA instead of meaningless value diff",
      "matchManagers": ["regex", "custom.regex"],
      "matchUpdateTypes": ["digest"],
      "groupName": null,
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "Regex-managed helm charts: add helm/ prefix, overrides topic from both version and digest regex rules above — commitMessageExtra is inherited from whichever of those matched first",
      "matchManagers": ["regex", "custom.regex"],
      "matchDatasources": ["helm"],
      "commitMessageTopic": "helm/{{depName}}"
    },
    {
      "description": "kubernetes images: docker/ prefix, strip org/registry path keeping only image name, include from/to versions and update type",
      "matchManagers": ["kubernetes"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "docker/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "kubernetes images digest: show short SHA instead of meaningless tag-name diff (e.g. latest to latest)",
      "matchManagers": ["kubernetes"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "docker/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "argocd: helm/ prefix, strip org/registry path keeping only chart name, include from/to versions and update type",
      "matchManagers": ["argocd"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "helm/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "argocd digest: show short SHA instead of meaningless version-name diff",
      "matchManagers": ["argocd"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "helm/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "helmfile/helm-values: helm/ prefix, strip org/registry keeping only chart name, include from/to versions and update type",
      "matchManagers": ["helmfile", "helm-values"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "helm/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "helmfile/helm-values digest: show short SHA instead of meaningless version-name diff",
      "matchManagers": ["helmfile", "helm-values"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "helm/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "terraform: terraform/ prefix, use resolved versions not constraint strings, include update type; bump range lower bound to the new version rather than widening the constraint",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "terraform/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})",
      "rangeStrategy": "bump"
    },
    {
      "description": "dockerfile: docker/ prefix, strip org/registry path keeping only image name, include from/to versions and update type",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "docker/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "dockerfile digest: show short SHA instead of meaningless tag-name diff",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "docker/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "npm: add npm/ prefix, use resolved versions not constraint strings, include update type; dedupe lock file after each update",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "npm/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})",
      "postUpdateOptions": ["npmDedupe"]
    },
    {
      "description": "composer: composer/ prefix, from/to resolved versions and update type",
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "composer/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})"
    },
    {
      "description": "composer digest: show short SHA instead of meaningless ref diff",
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "composer/{{depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "github-actions: action/ prefix, strip org keeping only action name, include from/to versions and update type",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "commitMessageTopic": "action/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "github-actions pin: lowercase action word, show target SHA, include update type (built-in uses capital Pin and overrides topic)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["pin"],
      "commitMessageAction": "pin",
      "commitMessageTopic": "action/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "to {{newDigestShort}} (pin)"
    },
    {
      "description": "github-actions digest: show short SHA instead of meaningless branch-name diff",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "action/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "pip_requirements: pip/ prefix, use constraint strings (deps may be unpinned), include update type",
      "matchManagers": ["pip_requirements"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "pip/{{depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "pip_requirements digest: show short SHA instead of meaningless ref diff",
      "matchManagers": ["pip_requirements"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "pip/{{depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "pep621/uv: pip/ prefix, use resolved versions (always pinned), include update type",
      "matchManagers": ["pep621", "uv"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "pip/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})"
    },
    {
      "description": "pep621/uv digest: show short SHA instead of meaningless ref diff",
      "matchManagers": ["pep621", "uv"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "pip/{{depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "pre-commit hooks: hook/ prefix, strip org keeping only hook name, include from/to versions and update type; use currentValue/newValue (raw tag) since some repos use non-semver tags where currentVersion would be empty",
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "hook/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "pre-commit hooks digest: show short SHA instead of meaningless ref diff",
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "hook/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "bundler: gem/ prefix, from/to resolved versions and update type",
      "matchManagers": ["bundler"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "gem/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})"
    },
    {
      "description": "bundler digest: show short SHA instead of meaningless ref diff",
      "matchManagers": ["bundler"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "gem/{{depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "docker-compose: docker/ prefix, strip org/registry keeping only image name, include from/to versions and update type",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "docker/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    },
    {
      "description": "docker-compose digest: show short SHA instead of meaningless tag-name diff",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "docker/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "cargo: rust/ prefix, use resolved versions, include update type",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "rust/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})"
    },
    {
      "description": "cargo digest: show short SHA instead of meaningless ref diff",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "rust/{{depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "gomod: go/ prefix, use resolved versions, include update type",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "go/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})"
    },
    {
      "description": "gomod digest: show short SHA instead of meaningless ref diff",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "go/{{depName}}",
      "commitMessageExtra": "{{currentDigestShort}} -> {{newDigestShort}} (digest)"
    },
    {
      "description": "maven: maven/ prefix, use resolved versions, include update type",
      "matchManagers": ["maven"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "maven/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})"
    },
    {
      "description": "gradle/gradle-wrapper: gradle/ prefix, use resolved versions, include update type",
      "matchManagers": ["gradle", "gradle-wrapper"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "gradle/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}} ({{updateType}})"
    },
    {
      "description": "nvm/.nvmrc/.node-version: node/ prefix, include from/to versions and update type",
      "matchManagers": ["nvm"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "node/{{depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}} ({{updateType}})"
    }
  ]
}
