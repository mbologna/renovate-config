{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prCreation": "not-pending",
  "pinDigests": true,
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "labels": [
    "dependencies"
  ],
  "rebaseWhen": "behind-base-branch",
  "platformAutomerge": true,
  "vulnerabilityAlerts": {
    "labels": [
      "dependencies",
      "security"
    ],
    "minimumReleaseAge": "0 days",
    "automerge": true,
    "automergeType": "pr"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "automergeStrategy": "squash",
    "commitMessageTopic": "lock file maintenance",
    "commitMessageExtra": "",
    "schedule": [
      "before 9am on monday"
    ]
  },
  "packageRules": [
    {
      "description": "Major updates: hold 30 days to let the ecosystem surface breaking changes and incompatibilities, then assign for manual review — no auto-merge",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "30 days",
      "automerge": false,
      "reviewers": [
        "mbologna"
      ]
    },
    {
      "description": "Patch updates: hold 7 days to let the community catch supply-chain attacks before auto-merging on green CI",
      "matchUpdateTypes": [
        "patch"
      ],
      "minimumReleaseAge": "7 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Digest updates: hold 7 days (same as patch) before auto-merging on green CI",
      "matchUpdateTypes": [
        "digest"
      ],
      "minimumReleaseAge": "7 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Pin updates: hold 7 days (same as patch) before auto-merging on green CI",
      "matchUpdateTypes": [
        "pin"
      ],
      "minimumReleaseAge": "7 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Minor updates: hold 14 days to let the community catch supply-chain attacks before auto-merging on green CI",
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "14 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "GitHub Actions: never auto-merge — workflow changes run with repo permissions and are a supply-chain risk",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": false,
      "groupName": null
    },
    {
      "description": "mbologna/.github reusable workflows: already age-gated by that repo's own Renovate run — skip stability window and automerge on green CI",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "mbologna/.github"
      ],
      "minimumReleaseAge": "0 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Security/CVE updates: bypass age gate and maintenance windows, jump the queue with prPriority 10, automerge immediately on green CI",
      "matchCategories": [
        "security"
      ],
      "minimumReleaseAge": "0 days",
      "prPriority": 10,
      "automerge": true,
      "automergeType": "pr",
      "schedule": [
        "at any time"
      ]
    },
    {
      "description": "Regex-managed versions: one PR per package; commitMessageExtra overrides config:recommended docker preset to include from/to versions",
      "matchManagers": [
        "regex"
      ],
      "groupName": null,
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "kubernetes images: prefix PR titles with docker/, strip docker.io/ registry, include from/to versions",
      "matchManagers": [
        "kubernetes"
      ],
      "commitMessageTopic": "docker/{{replace 'docker.io/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "argocd: prefix PR titles with helm/, include from/to versions",
      "matchManagers": [
        "argocd"
      ],
      "commitMessageTopic": "helm/{{depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "terraform: prefix PR titles with terraform/; use resolved versions not constraint strings",
      "matchManagers": [
        "terraform"
      ],
      "commitMessageTopic": "terraform/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}}"
    },
    {
      "description": "github-actions: prefix PR titles with action/, include from/to versions",
      "matchManagers": [
        "github-actions"
      ],
      "commitMessageTopic": "action/{{depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    }
  ]
}
