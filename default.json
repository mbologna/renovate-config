{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prCreation": "not-pending",
  "pinDigests": true,
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "labels": [
    "dependencies"
  ],
  "commitMessageAction": "update",
  "rebaseWhen": "behind-base-branch",
  "platformAutomerge": true,
  "vulnerabilityAlerts": {
    "labels": [
      "dependencies",
      "security"
    ],
    "minimumReleaseAge": "0 days",
    "automerge": true,
    "automergeType": "pr"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "automergeStrategy": "squash",
    "commitMessagePrefix": "chore:",
    "commitMessageAction": "lock file maintenance",
    "schedule": [
      "before 9am on monday"
    ]
  },
  "packageRules": [
    {
      "description": "Major updates: hold 30 days to let the ecosystem surface breaking changes and incompatibilities, then assign for manual review — no auto-merge",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "30 days",
      "automerge": false,
      "commitMessagePrefix": "chore(major):",
      "reviewers": [
        "mbologna"
      ]
    },
    {
      "description": "Patch updates: hold 7 days to let the community catch supply-chain attacks before auto-merging on green CI",
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "7 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "commitMessagePrefix": "chore(patch):"
    },
    {
      "description": "Digest updates: hold 7 days (same as patch) before auto-merging on green CI",
      "matchUpdateTypes": ["digest"],
      "minimumReleaseAge": "7 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "commitMessagePrefix": "chore(digest):"
    },
    {
      "description": "Pin updates: hold 7 days (same as patch) before auto-merging on green CI",
      "matchUpdateTypes": ["pin"],
      "minimumReleaseAge": "7 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "commitMessagePrefix": "chore(pin):"
    },
    {
      "description": "Minor updates: hold 14 days to let the community catch supply-chain attacks before auto-merging on green CI",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "14 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "commitMessagePrefix": "chore(minor):"
    },
    {
      "description": "GitHub Actions: never auto-merge — workflow changes run with repo permissions and are a supply-chain risk",
      "matchManagers": ["github-actions"],
      "automerge": false,
      "groupName": null
    },
    {
      "description": "mbologna/.github reusable workflows: already age-gated by that repo's own Renovate run — skip stability window and automerge on green CI",
      "matchManagers": ["github-actions"],
      "matchDepNames": ["mbologna/.github"],
      "minimumReleaseAge": "0 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Security/CVE updates: bypass age gate and maintenance windows, jump the queue with prPriority 10, automerge immediately on green CI",
      "matchCategories": ["security"],
      "minimumReleaseAge": "0 days",
      "prPriority": 10,
      "automerge": true,
      "automergeType": "pr",
      "schedule": ["at any time"]
    },
    {
      "description": "Regex-managed versions: one PR per package; commitMessageExtra overrides config:recommended docker preset to include from/to versions",
      "matchManagers": ["regex"],
      "groupName": null,
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "Regex-managed helm charts: add helm/ prefix (overrides generic regex rule above)",
      "matchManagers": ["regex"],
      "matchDatasources": ["helm"],
      "commitMessageTopic": "helm/{{depName}}"
    },
    {
      "description": "kubernetes images: docker/ prefix, strip org/registry path keeping only image name, include from/to versions",
      "matchManagers": ["kubernetes"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "commitMessageTopic": "docker/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "argocd: helm/ prefix, strip org/registry path keeping only chart name, include from/to versions",
      "matchManagers": ["argocd"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "commitMessageTopic": "helm/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "terraform: terraform/ prefix, use resolved versions not constraint strings; matchUpdateTypes excludes lockFileMaintenance",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "commitMessageTopic": "terraform/{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}}"
    },
    {
      "description": "dockerfile: docker/ prefix, strip org/registry path keeping only image name, include from/to versions",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "commitMessageTopic": "docker/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "npm: drop redundant 'dependency' word from topic; use resolved versions (currentVersion/newVersion) not constraint strings",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "from {{currentVersion}} to {{newVersion}}"
    },
    {
      "description": "composer: normalize action to lowercase, include from/to versions",
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "github-actions: action/ prefix, strip org keeping only action name, include from/to versions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "commitMessageTopic": "action/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "from {{currentValue}} to {{newValue}}"
    },
    {
      "description": "github-actions digest: show short SHA instead of meaningless branch-name diff",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest"],
      "commitMessageTopic": "action/{{replace '.+/' '' depName}}",
      "commitMessageExtra": "{{currentDigestShort}} → {{newDigestShort}}"
    }
  ]
}
